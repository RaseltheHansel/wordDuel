{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "outDir": "./disc",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "types": ["node"]


    },
    "include": ["src/**/*"],
    "exclude": ["node_modules/", "dist"]
}